# ==================================================
# ROS Monitor Frontend - 环境变量配置示例
# ==================================================

# 后端API主机地址
# 留空则自动检测浏览器访问的hostname (推荐)
# 示例: localhost, 192.168.1.100, api.example.com
VITE_API_HOST=

# 后端API端口
# 默认: 8001
VITE_API_PORT=8001

# WebSocket地址 (可选，一般不需要配置)
# 会根据 API_HOST 和 API_PORT 自动生成
# VITE_WS_URL=ws://localhost:8001

# 应用标题
VITE_APP_TITLE=ROS远程监控系统

# ==================================================
# 使用说明
# ==================================================
# 1. 复制此文件为 .env.local 用于本地开发
# 2. 复制此文件为 .env.production 用于生产环境
# 3. 大多数情况下 VITE_API_HOST 留空即可，系统会自动检测
# 4. 只在需要指定特定后端地址时才配置 VITE_API_HOST
#
# 自动检测规则:
# - 访问 http://localhost:5173 → 连接 ws://localhost:8001
# - 访问 http://192.168.43.127:5173 → 连接 ws://192.168.43.127:8001
# - 访问 http://example.com → 连接 ws://example.com:8001
