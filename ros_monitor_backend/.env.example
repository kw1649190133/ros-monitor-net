# ROS监控系统后端环境变量配置示例
# 复制此文件为 .env 并根据实际情况修改

# 后端服务端口
ROS_MONITOR_PORT=8001

# -----------------------------------------------------------
# rosbridge 连接配置（替代原 rospy 直连）
# 后端通过 rosbridge WebSocket 远程订阅 ROS topic
# 机器人端需要先启动: roslaunch rosbridge_server rosbridge_websocket.launch
# -----------------------------------------------------------

# rosbridge 服务器地址（机器人的 IP）
ROSBRIDGE_HOST=localhost

# rosbridge 端口（默认 9090）
ROSBRIDGE_PORT=9090
